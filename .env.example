# Telegram Channels Configuration
# UPDATED COMMENTS: Channel URLs for widgets and parsers - copy to .env and fill with real values

# Main portfolio channel
TELEGRAM_CHANNEL_MAIN=https://t.me/your_channel

# Additional channel
TELEGRAM_CHANNEL_KNOPOCHKIN=https://t.me/your_second_channel

# Backend API endpoint
API_BASE_URL=http://localhost:8000

# Telegram Bot Configuration for Contact Messages
# UPDATED COMMENTS: Get bot token from @BotFather, chat ID from @userinfobot
# SECURITY: Never commit real tokens to git!
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
