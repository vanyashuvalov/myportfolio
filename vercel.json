{
  "buildCommand": "echo 'Python serverless - no build needed'",
  "outputDirectory": ".",
  "installCommand": "pip install -r requirements.txt 2>/dev/null || echo 'No Python deps'",
  "rewrites": [
    { "source": "/projects", "destination": "/projects/index.html" },
    { "source": "/projects/(.*)", "destination": "/projects/index.html" },
    { "source": "/fun", "destination": "/fun/index.html" },
    { "source": "/fun/(.*)", "destination": "/fun/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
