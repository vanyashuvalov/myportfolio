{
  "buildCommand": "echo 'Python serverless - no build needed'",
  "outputDirectory": ".",
  "installCommand": "pip install -r requirements.txt 2>/dev/null || echo 'No Python deps'",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
