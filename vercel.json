{
  "buildCommand": "echo 'Python serverless - no build needed'",
  "outputDirectory": ".",
  "installCommand": "pip install -r requirements.txt 2>/dev/null || echo 'No Python deps'",
  "rewrites": [
    {
      "source": "/:file(html|css|js|json|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)",
      "destination": "/:file"
    },
    {
      "source": "/:path*.html",
      "destination": "/:path*.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
